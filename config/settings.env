# settings.env - ツール設定ファイル
# 環境に合わせて変更してください。

# ---- ログ種別 ----
# syslog   : logger コマンドで syslog に記録（/var/log/syslog 等）
# journald : logger コマンドで journald に記録（journalctl で参照）
# file     : LOG_FILE で指定したファイルに直接記録
# stdout   : 標準出力に出力（リダイレクトして利用）
LOG_TYPE=syslog

# ---- ファイルログ使用時のパス（LOG_TYPE=file の場合）----
# LOG_FILE=/var/log/myapp/app.log

# ---- 識別子管理ファイルパス ----
# MARKERS_FILE=/opt/test-tools/markers/test_markers.csv

# ---- エビデンス出力先ディレクトリ ----
# EVIDENCE_DIR=/opt/test-tools/evidence

# ---- 抽出モード ----
# strict : 終了マーカーがない場合、次マーカー直前まで抽出
# loose  : 終了マーカーがない場合、開始マーカーから FALLBACK_LINES 行を抽出
EXTRACT_MODE=strict

# ---- 終了マーカーなし時のフォールバック行数 ----
FALLBACK_LINES=500

# ---- ログ形式（将来の拡張用）----
# auto | syslog | application | journalctl
LOG_FORMAT=auto
